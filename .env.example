# User credentials
USERNAME=your_username_here

# GitHub API configuration
GITHUB_API_URL=https://api.github.com
GITHUB_TOKEN=your_github_token_here

# Netlify API configuration
NETLIFY_API_URL=https://api.netlify.com/api/v1
NETLIFY_TOKEN=your_netlify_token_here

# Vercel API configuration
VERCEL_API_URL=https://api.vercel.com
VERCEL_TOKEN=your_vercel_token_here

# Render API configuration
RENDER_API_URL=https://api.render.com/v1
RENDER_TOKEN=your_render_token_here

# CORS configuration
# Use "*" for all origins, or comma-separated origins for allowlist
CORS_ORIGIN=*
CORS_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_HEADERS=Content-Type,Authorization,Accept
# Optional
# CORS_EXPOSE_HEADERS=
# CORS_ALLOW_CREDENTIALS=false
# CORS_MAX_AGE=86400

# API key auth
# Comma-separated API keys accepted in Authorization: Bearer <key>
# API_KEYS=portfolio_public_key,your_other_client_key
# Optional (defaults to true in production, false otherwise)
# API_KEY_REQUIRED=false
# Optional x-api-key fallback support (default true)
# API_KEY_ALLOW_X_HEADER=true
# Trust proxy-forwarded IP headers (x-forwarded-for, x-real-ip, cf-connecting-ip)
# Only enable when your ingress/proxy sanitizes these headers.
# TRUST_PROXY_HEADERS=false

# Rate limiting
# Optional (defaults to true in production, false otherwise)
# RATE_LIMIT_ENABLED=false
# RATE_LIMIT_MAX=120
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_HEADERS=true
